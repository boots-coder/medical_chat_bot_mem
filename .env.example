# API Configuration
API_PROVIDER=ark  # Options: ark, openrouter, openai
API_KEY=your_api_key_here
API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
API_MODEL=deepseek-v3-250324

# Database Configuration
SQLITE_DB_PATH=./data/sessions.db
CHROMA_PERSIST_DIR=./data/chroma
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# JWT Configuration
JWT_SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
TOKEN_EXPIRE_MINUTES=30

# Session Configuration
SESSION_TIMEOUT_MINUTES=30
MAX_DIALOGUE_TURNS=100  # Trigger clustering threshold

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# CORS Configuration (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Clustering Configuration
CLUSTER_MIN_SIZE=3
CLUSTER_MIN_SAMPLES=2
SBERT_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Memory Configuration
SHORT_TERM_MAX_TOKENS=2000
SHORT_TERM_MAX_TURNS=10
